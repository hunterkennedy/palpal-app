# Postgres
POSTGRES_USER=palpal
POSTGRES_PASSWORD=changeme
POSTGRES_DB=palpal

# Connection string (consumed by conductor)
DATABASE_URL=postgresql://palpal:changeme@postgres:5432/palpal

# Frontend
APP_PORT=3001
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
CONDUCTOR_URL=http://palpal-conductor:8000
CONDUCTOR_ADMIN_KEY=changeme-admin-secret
ADMIN_PASSWORD=changeme-admin-password
ADMIN_SESSION_TOKEN=changeme-long-random-string

# Conductor
CONDUCTOR_PORT=8000
BLURB_API_KEY=changeme-blurb-secret
AUDIO_HOST_PATH=/opt/palpal-audio

# Backblaze B2 (transcript storage)
B2_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com
B2_KEY_ID=your-b2-key-id
B2_APP_KEY=your-b2-app-key
B2_BUCKET=your-bucket-name

# Image
GHCR_USER=your-github-username
IMAGE_TAG=latest
