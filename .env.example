# Postgres
POSTGRES_USER=palpal
POSTGRES_PASSWORD=changeme
POSTGRES_DB=palpal

# Connection string (consumed by conductor)
DATABASE_URL=postgresql://palpal:changeme@postgres:5432/palpal

# Frontend
APP_PORT=3001
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
CONDUCTOR_URL=http://palpal-conductor:8000
ADMIN_PASSWORD=changeme-admin-password

# Conductor
CONDUCTOR_PORT=8000
BLURB_API_KEY=changeme-blurb-secret
CONDUCTOR_ADMIN_KEY=changeme-admin-secret
AUDIO_HOST_PATH=/home/hunter/palpal-audio
