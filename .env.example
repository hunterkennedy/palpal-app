# Postgres
POSTGRES_USER=palpal
POSTGRES_PASSWORD=changeme
POSTGRES_DB=palpal

# Connection string (consumed by conductor)
DATABASE_URL=postgresql://palpal:changeme@postgres:5432/palpal

# Temporal (shares same postgres; auto-setup creates temporal + temporal_visibility DBs)
TEMPORAL_DB_PLUGIN=postgres12
TEMPORAL_DB_HOST=postgres
TEMPORAL_DB_PORT=5432
TEMPORAL_DB_USER=palpal
TEMPORAL_DB_PASSWORD=changeme
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_UI_PORT=8080

# Frontend
APP_PORT=3001
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
CONDUCTOR_URL=http://palpal-conductor:8000

# Conductor (not built yet)
CONDUCTOR_PORT=8000
BLURB_API_KEY=changeme-blurb-secret
