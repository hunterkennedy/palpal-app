# Frontend
APP_PORT=3001
NODE_ENV=production

# Conductor public URL (via Cloudflare tunnel)
CONDUCTOR_URL=https://api.palpal.app

# Must match conductor's CONDUCTOR_ADMIN_KEY
# Note: /admin/* is blocked at the tunnel — admin panel will not work remotely.
# Admin operations must be done via SSH tunnel to the conductor server.
CONDUCTOR_ADMIN_KEY=changeme-admin-secret

# Contact email (shown in TOS, Privacy Policy, About)
NEXT_PUBLIC_CONTACT_EMAIL=example@example.org

# Build
NEXT_TELEMETRY_DISABLED=1

# Image
GHCR_USER=your-github-username
IMAGE_TAG=latest
