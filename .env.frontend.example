# Frontend
APP_PORT=3001
NODE_ENV=production

# Conductor internal URL (Docker network — frontend calls conductor directly)
CONDUCTOR_URL=http://palpal-conductor:8000

# Admin panel auth — must match conductor's CONDUCTOR_ADMIN_KEY
# The admin panel is served by the frontend at /admin (session-authenticated)
CONDUCTOR_ADMIN_KEY=changeme-admin-secret
ADMIN_PASSWORD=changeme-admin-password
ADMIN_SESSION_TOKEN=changeme-long-random-string

# Contact email (shown in TOS, Privacy Policy, About)
NEXT_PUBLIC_CONTACT_EMAIL=example@example.org

# Build
NEXT_TELEMETRY_DISABLED=1

# Image
GHCR_USER=your-github-username
IMAGE_TAG=latest
