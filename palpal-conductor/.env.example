DATABASE_URL=postgresql://palpal:changeme@postgres:5432/palpal
BLURB_URL=http://host.docker.internal:8001
BLURB_API_KEY=changeme-blurb-secret
CONDUCTOR_ADMIN_KEY=changeme-admin-secret
PORT=8000

# Backblaze B2 (transcript storage) — B2_ENDPOINT_URL/B2_KEY_ID/B2_APP_KEY/B2_BUCKET
# are required unless B2_DISABLED=true (local/testing only; disables transcript
# storage instead of erroring on missing config).
# B2_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com
# B2_KEY_ID=your-b2-key-id
# B2_APP_KEY=your-b2-app-key
# B2_BUCKET=your-bucket-name
# B2_DISABLED=true

# Optional tuning
# DB_POOL_MIN=4
# DB_POOL_MAX=20
# BLURB_POLL_INTERVAL=15
# BLURB_POLL_TIMEOUT=7200
# DOWNLOAD_CONCURRENCY=1
# TRANSCRIBE_CONCURRENCY=1
