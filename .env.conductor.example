# Postgres
POSTGRES_USER=palpal
POSTGRES_PASSWORD=changeme
POSTGRES_DB=palpal

# Connection string (consumed by conductor)
DATABASE_URL=postgresql://palpal:changeme@postgres:5432/palpal

# Conductor
CONDUCTOR_PORT=8000
CONDUCTOR_ADMIN_KEY=changeme-admin-secret

# Blurb worker (pulls jobs from conductor — no URL needed here)
# The shared secret must match BLURB_API_KEY in blurb's .env
BLURB_API_KEY=changeme-blurb-secret

# Audio volume mount (host path on conductor server)
AUDIO_HOST_PATH=/opt/palpal-audio

# Image
GHCR_USER=your-github-username
IMAGE_TAG=latest
