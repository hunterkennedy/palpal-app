# .env.example - Default Development Configuration
# Copy this to .env and modify as needed

# --- Docker Compose Specific Variables ---
COMPOSE_PROJECT_NAME=palpal

# --- Development Environment Variables ---
# For PRODUCTION: Change NODE_ENV=production
NODE_ENV=development
APP_PORT=3001
PORT=3001
APP_HOST=0.0.0.0

# Meilisearch Configuration
MEILI_MASTER_KEY=your-meili-master-key-here
MEILI_ENV=development
MEILI_PORT=7700
MEILI_HOST=0.0.0.0

# Next.js App Variables
# For PRODUCTION: Change to your actual domain (e.g., https://yourdomain.com)
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700

# Meilisearch API Keys - NEVER commit real keys to version control
MEILISEARCH_ADMIN_KEY=your-admin-key-here-keep-secret
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=your-search-only-key-here

# Docker Configuration - Development Setup
# For PRODUCTION: Change all "-dev" suffixes to "-prod"
MEILISEARCH_CONTAINER_NAME=palpal-meilisearch-dev
APP_CONTAINER_NAME=palpal-app-dev
NETWORK_NAME=palpal-network-dev

# Volume Configuration
# For PRODUCTION: Consider using a named volume or external mount
VOLUME_NAME=meilisearch_data_vol

# Build Configuration
NEXT_TELEMETRY_DISABLED=1


# Production Environment Configuration
# Set these to push transcripts to production while running locally
PROD_APP_HOST=https://your-production-domain.com
PROD_MEILISEARCH_ADMIN_KEY=your-production-admin-key

# Pipeline Processing Configuration
# Local app host for API communication during indexing
APP_HOST=http://localhost:3001
