# .env.example - Frontend development defaults
# Copy to .env and adjust as needed

NODE_ENV=development
APP_PORT=3001
PORT=3001

# Runtime URL for palpal-conductor (server-side only, no NEXT_PUBLIC_ prefix)
CONDUCTOR_URL=http://localhost:8000

# Contact email (shown in TOS, Privacy Policy, About)
NEXT_PUBLIC_CONTACT_EMAIL=example@example.org

# Build
NEXT_TELEMETRY_DISABLED=1
