{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev (frontend + live conductor)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/palpal-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "envFile": "${workspaceFolder}/palpal-frontend/.env.local",
      "serverReadyAction": {
        "pattern": "ready on .*(https?://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      },
      "preLaunchTask": "Run conductor (live)"
    },
  ]
}
